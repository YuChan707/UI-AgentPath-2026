# Safe env template for Docker. Copy to `.env` and fill in real values.
# Never commit the real .env.

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgresql://user:password@host:5432/onlooker

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=/app/chroma_data

# --- Data Commons ---
DATACOMMONS_API_KEY=
