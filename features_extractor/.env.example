# features-extractor — copy to .env and adjust. All local, no cloud.

# Postgres (writes products.features)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onlooker

# Ollama (OpenAI-compatible endpoint for the LangGraph agent)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
OLLAMA_API_KEY=ollama

# ChromaDB server (reads the product's chunks)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Dapr pub/sub
REDIS_HOST=localhost:6379
DAPR_HTTP_PORT=3500
PUBSUB_NAME=pubsub

# Optional: UiPath Orchestrator (for `uipath pack`/publish + monitoring)
UIPATH_URL=
UIPATH_ACCESS_TOKEN=
UIPATH_FOLDER=
