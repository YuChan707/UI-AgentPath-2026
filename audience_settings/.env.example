# audience-settings — copy to .env and adjust. All local, no cloud.

# Postgres (reads features+settings, writes audience_responses)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onlooker

# Ollama (OpenAI-compatible endpoint for the reaction agent)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
OLLAMA_API_KEY=ollama

# Dynamic parallelism for the local Ollama (defaults to CPU count if unset)
OLLAMA_NUM_PARALLEL=

# Dapr pub/sub
REDIS_HOST=localhost:6379
DAPR_HTTP_PORT=3500
PUBSUB_NAME=pubsub

# Optional: UiPath Orchestrator (uipath pack/publish + monitoring)
UIPATH_URL=
UIPATH_ACCESS_TOKEN=
UIPATH_FOLDER=
