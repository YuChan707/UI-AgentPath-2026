# embeding-service — copy to .env and adjust. All local, no cloud.

# Postgres (reads products.content by id)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onlooker

# Ollama (native API for embeddings)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Concurrent embedding requests in flight (defaults to CPU count if unset)
OLLAMA_NUM_PARALLEL=

# ChromaDB server
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Dapr pub/sub
REDIS_HOST=localhost:6379
DAPR_HTTP_PORT=3500
PUBSUB_NAME=pubsub
