# data_processor — copy to .env and adjust. All local, no cloud.

# LLM transport: auto | dapr | http | mock
LLM_TRANSPORT=auto
# OpenAI-compatible endpoint of the local Ollama (http transport)
LLAMA_BASE_URL=http://localhost:11434/v1
LLAMA_MODEL=llama3.1
LLAMA_API_KEY=ollama

# Optional: Data Commons enrichment (build_profiles / fetch_data_commons)
DATACOMMONS_API_KEY=
