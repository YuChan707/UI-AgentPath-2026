# Copy this file to .env and fill in your values
# NEVER commit .env — only commit this .env.example

DATABASE_URL=sqlite+aiosqlite:///./onlooker.db
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
DATABASE_POOL_URL=

# AI / LLM — fully local Ollama (no cloud).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
# data_processor transport (OpenAI-compatible endpoint of the same Ollama)
LLAMA_BASE_URL=http://localhost:11434/v1
LLAMA_MODEL=llama3.1

# App
MOCK_MODE=false
ENVIRONMENT=development
CHROMA_OPEN_TELEMETRY__ENDPOINT=http://localhost:4317
CHROMA_OPEN_TELEMETRY__SERVICE_NAME=chroma-local
OTEL_EXPORTER_OTLP_HEADERS=
