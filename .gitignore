# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Python #
##########
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editors / virtualenv #
########################
.venv/
venv/
.idea/
.vscode/

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sqlite
*.sqlite3
# Ignore ad-hoc SQL dumps, but keep versioned schema/seed under postgresql-db/
*.sql
!containers_env/postgresql-db/*.sql

# Node / Next.js (frontend) #
#############################
node_modules/
.next/
out/
next-env.d.ts

# Env files #
#############
.env
.env.local
.env.*.local

# ChromaDB local persistent storage (keep the dir, ignore its data) #
####################################################################
chroma_data/*
!chroma_data/.gitkeep

# Pipeline generated artifacts (data SINTETICA / persistida en runtime) #
########################################################################
# Salidas del data_processor (specs de audiencia, modelos, grupos)
data_processor/output/
# Ubicaciones persistidas por el data_ingestor (se regeneran desde el Census)
data_ingestor/data/locations/
# Conservar los CSV de entrada (zip codes NY)
!data_ingestor/data/*.csv

# Local DB files + extras (de imp/database) #
#############################################
*.db
onlooker.db
.gitignore.env
*.pyo

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
memory/